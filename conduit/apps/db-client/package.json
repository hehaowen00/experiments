{
  "name": "@conduit/db-client",
  "version": "1.0.0",
  "private": true,
  "description": "Conduit Database Client — PostgreSQL + SQLite workspace",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "build": "npm run build --workspace=@conduit/db-client-ui",
    "dev": "npm run dev --workspace=@conduit/db-client-ui",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.conduit.db-client",
    "productName": "Conduit DB Client",
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "ui/dist/**/*",
      "node_modules/**/*"
    ],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "@conduit/core": "*",
    "better-sqlite3": "^12.6.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1"
  }
}
