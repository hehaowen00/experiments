{
  "name": "conduit",
  "version": "1.0.0",
  "private": true,
  "description": "Conduit — API client, database client, and developer toolbox",
  "workspaces": [
    "apps/*",
    "apps/*/ui",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dev:api": "npm run dev --workspace=apps/api-client",
    "dev:db": "npm run dev --workspace=apps/db-client",
    "dev:toolbox": "npm run dev --workspace=apps/toolbox",
    "start:api": "npm run start --workspace=apps/api-client",
    "start:db": "npm run start --workspace=apps/db-client",
    "start:toolbox": "npm run start --workspace=apps/toolbox",
    "build": "npm run build --workspaces --if-present",
    "dist": "npm run dist --workspaces --if-present",
    "dist:mac": "npm run dist:mac --workspaces --if-present",
    "dist:win": "npm run dist:win --workspaces --if-present",
    "dist:linux": "npm run dist:linux --workspaces --if-present"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "prettier": "^3.8.1"
  }
}
